[debug] [2026-03-14T13:34:07.477Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/sem3-minor/rulesets {"name":"projects/sem3-minor/rulesets/2be65a31-a7fa-4c1e-96b9-b0049db7cd8d","source":{"files":[{"content":"rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    function isAuth()       { return request.auth != null; }\n    function uid()          { return request.auth.uid; }\n    function userDoc()      { return get(/databases/$(database)/documents/users/$(uid())); }\n    function role()         { return userDoc().data.role; }\n    function isAdmin()      { return role() == 'superAdmin'; }\n    function isRO()         { return role() == 'regionalOfficer'; }\n    function isTeam()       { return role() == 'monitoringTeam'; }\n    function isIndustry()   { return role() == 'industryUser'; }\n    function userRoId()     { return userDoc().data.roId; }\n    function isTempBridgeWrite() {\n      return isAuth() &&\n             request.resource.data.bridgeMode == 'clientOrchestrated';\n    }\n\n    match /users/{userId} {\n      allow read:  if isAuth() && (uid() == userId || isAdmin());\n      allow create: if isAdmin();\n      allow update: if isAdmin() || uid() == userId;\n      allow delete: if isAdmin();\n    }\n\n    match /regionalOffices/{id} {\n      allow read:  if isAuth();\n      allow write: if isAdmin();\n    }\n    match /industries/{id} {\n      allow read:  if isAuth();\n      allow write: if isAdmin() || isTempBridgeWrite();\n    }\n    match /monitoringLocations/{id} {\n      allow read:  if isAuth();\n      allow write: if isAdmin() || isTempBridgeWrite();\n    }\n    match /units/{id} {\n      allow read:  if isAuth();\n      allow write: if isAdmin();\n    }\n    match /prescribedLimits/{id} {\n      allow read:  if isAuth();\n      allow write: if isAdmin();\n    }\n    match /monitoringTeams/{id} {\n      allow read:  if isAuth();\n      allow write: if isAdmin();\n    }\n\n    match /airReadings/{id} {\n      allow read:  if isAuth() && (isAdmin() || isRO() || resource.data.roId == userRoId());\n      allow create: if isAuth() && (isAdmin() || isRO() || isTeam() || isIndustry());\n      allow update: if isAdmin();\n      allow delete: if isAdmin();\n    }\n    match /waterReadings/{id} {\n      allow read:  if isAuth() && (isAdmin() || isRO() || resource.data.roId == userRoId());\n      allow create: if isAuth() && (isAdmin() || isRO() || isTeam() || isIndustry());\n      allow update: if isAdmin();\n      allow delete: if isAdmin();\n    }\n    match /noiseReadings/{id} {\n      allow read:  if isAuth() && (isAdmin() || isRO() || resource.data.roId == userRoId());\n      allow create: if isAuth() && (isAdmin() || isRO() || isTeam() || isIndustry());\n      allow update: if isAdmin();\n      allow delete: if isAdmin();\n    }\n\n    match /violations/{id} {\n      allow read:  if isAuth() && (isAdmin() || (isRO() && resource.data.roId == userRoId()));\n      allow write: if isTempBridgeWrite();\n    }\n\n    match /escalations/{id} {\n      allow read:  if isAuth() && (isAdmin() || (isRO() && resource.data.roId == userRoId()));\n      allow update: if (isAuth() && (isAdmin() || isRO())) || isTempBridgeWrite();\n      allow create: if isTempBridgeWrite();\n      allow delete: if isAdmin();\n      match /timeline/{entryId} {\n        allow read:  if isAuth() && (isAdmin() || isRO());\n        allow write: if isTempBridgeWrite();\n      }\n    }\n\n    match /notifications/{id} {\n      allow read:  if isAuth() && (isAdmin() ||\n                     resource.data.recipientUid  == uid() ||\n                     resource.data.recipientRoId == userRoId());\n      allow update: if (isAuth() && (isAdmin() ||\n                     resource.data.recipientUid  == uid() ||\n                     resource.data.recipientRoId == userRoId())) || isTempBridgeWrite();\n      allow create: if isTempBridgeWrite();\n      allow delete: if isAdmin();\n    }\n\n    match /reportLocks/{id} {\n      allow read:  if isAuth();\n      allow write: if false;\n    }\n\n    match /forecasts/{id} {\n      allow read:  if isAuth();\n      allow write: if false;\n    }\n\n    match /publicSummary/{id} {\n      allow read:  if true;\n      allow write: if isTempBridgeWrite();\n    }\n\n    match /supportTickets/{id} {\n      allow read:  if isAuth() && (isAdmin() || resource.data.createdBy == uid());\n      allow create: if isAuth();\n      allow update: if isAdmin();\n      allow delete: if isAdmin();\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-03-14T13:34:08.245839Z","metadata":{"services":["cloud.firestore"]}}
